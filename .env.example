# Copy this file to .env for local Docker Compose usage.
# Do not commit .env. Keep real secrets in your deployment secret store.

# Android build config. Publishable key is safe for client code when RLS is correct.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Unified Kotlin/Ktor backend runtime.
UMKMSHOP_BACKEND_PORT=8090

# Notification worker runs inside the backend process.
# Local HTTP/OAuth-only development may use false. Production should use true so missing DB/FCM config fails fast.
UMKMSHOP_WORKER_ENABLED=false
UMKMSHOP_BACKEND_DATABASE_URL=jdbc:postgresql://PROJECT_REF.pooler.supabase.com:6543/postgres?user=postgres.PROJECT_REF&password=REPLACE_ME&sslmode=require
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"REPLACE_ME"}
UMKMSHOP_BACKEND_QUEUE_NAME=notifications
UMKMSHOP_BACKEND_MAX_ATTEMPTS=5
UMKMSHOP_BACKEND_VISIBILITY_TIMEOUT_SECONDS=30
UMKMSHOP_BACKEND_BATCH_SIZE=10
UMKMSHOP_BACKEND_MAX_CONCURRENCY=8
UMKMSHOP_BACKEND_EMPTY_POLL_DELAY_MS=2000
UMKMSHOP_BACKEND_DB_POOL_MAX_SIZE=8

# Legacy worker env names remain accepted by backend code when easy to reuse.
# UMKMSHOP_DATABASE_URL=
# UMKMSHOP_QUEUE_NAME=

# OAuth learning server routes are mounted in the same backend process.
UMKMSHOP_OAUTH_ISSUER=http://localhost:8090
UMKMSHOP_OAUTH_TOKEN_PEPPER=replace-with-a-long-random-local-only-value
UMKMSHOP_OAUTH_DEMO_REDIRECT_URI=http://localhost:8090/demo/callback
UMKMSHOP_OAUTH_DEMO_USER_ID=00000000-0000-0000-0000-000000000027
UMKMSHOP_OAUTH_DEMO_USER_EMAIL=demo@umkmshop.local
UMKMSHOP_OAUTH_DEMO_USER_NAME=Demo UMKMShop User
UMKMSHOP_OAUTH_DEMO_CLIENT_ID=umkmshop-demo-public
UMKMSHOP_OAUTH_DEMO_CLIENT_NAME=UMKMShop Demo Public Client

# Android SDK image build knobs.
ANDROID_CMDLINE_TOOLS_VERSION=13114758
ANDROID_AVD_NAME=umkmshop-api36
