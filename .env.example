# === KONFIGURASI ANDROID (BUILD TIME) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# === KONFIGURASI BACKEND (RUNTIME) ===
UMKMSHOP_BACKEND_PORT=8090
UMKMSHOP_WORKER_ENABLED=true
UMKMSHOP_OAUTH_USE_JDBC=true

# 1. DATABASE SECRET (Gunakan Port 6543 Supavisor untuk Produksi)
# Format: jdbc:postgresql://[REF].pooler.supabase.com:6543/postgres?user=postgres.[REF]&password=[PASSWORD]&sslmode=require&prepareThreshold=0
UMKMSHOP_BACKEND_DATABASE_URL=

# 2. FIREBASE SECRET (Tempel isi file JSON Service Account dalam satu baris)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# 3. SUPABASE OAUTH SECRET (Diambil dari Dashboard Supabase > Settings > API)
SUPABASE_JWT_SECRET=isi-jwt-secret-project-anda

# 4. OAUTH SECURITY (Buat string acak yang panjang dan unik)
UMKMSHOP_OAUTH_TOKEN_PEPPER=buat-string-acak-di-sini
UMKMSHOP_OAUTH_ISSUER=https://api.umkmshop.com

# 5. REGISTERED REDIRECT URIS (Daftar URL yang diizinkan, pisahkan dengan koma)
UMKMSHOP_OAUTH_DEMO_REDIRECT_URI=https://app.umkmshop.com/callback,http://localhost:3000/
